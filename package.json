    "react-dom": "19.2.7",
    "react-redux": "9.3.0",
    "redux": "5.0.1",
    "reselect": "5.2.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "fmt": "oxfmt --write .",
    "fmt.check": "oxfmt --check .",
    "lint:js": "oxlint . --report-unused-disable-directives --max-warnings 0",
    "lint:css": "stylelint \"**/*.css\" --max-warnings 0 --allow-empty-input --cache --cache-strategy=content --cache-location=.stylelintcache",
    "lint": "run-p lint:js lint:css",
    "playwright": "playwright",
    "preview": "vite preview",
    "test": "vitest",
    "test.ui": "vitest --ui",
    "typecheck": "tsc",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "pnpm@11.8.0"
}
