    "storybook": "10.4.6",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-order": "8.1.1",
    "tailwindcss": "4.3.1",
    "typed-query-selector": "2.12.2",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@reduxjs/toolkit": "2.12.0",
    "clsx": "2.1.1",
    "motion": "12.40.0",
